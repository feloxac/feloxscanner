{
    "name":  "felox-scanner",
    "version":  "1.0.0",
    "description":  "FiveM Cheat Scanner",
    "main":  "main.js",
    "scripts":  {
                    "start":  "electron .",
                    "prepare:icon":  "node scripts/prepare-icon.js",
                    "dist:win":  "set CSC_IDENTITY_AUTO_DISCOVERY=false \u0026\u0026 npm run prepare:icon \u0026\u0026 electron-builder --win portable --x64",
                    "dist:dir":  "set CSC_IDENTITY_AUTO_DISCOVERY=false \u0026\u0026 npm run prepare:icon \u0026\u0026 electron-builder --win dir --x64"
                },
    "devDependencies":  {
                            "electron":  "^28.0.0",
                            "electron-builder":  "^24.13.3",
                            "sharp":  "^0.34.5"
                        },
    "build":  {
                  "appId":  "com.felox.scanner",
                  "productName":  "FeloxAC Scanner",
                  "asar":  true,
                  "files":  [
                                "main.js",
                                "preload.js",
                                "renderer.js",
                                "index.html",
                                "style.css",
                                "build/icon.png"
                            ],
                  "directories":  {
                                      "buildResources":  "build",
                                      "output":  "release"
                                  },
                  "artifactName":  "FeloxAC-Scanner-${version}-${arch}.${ext}",
                  "win":  {
                              "target":  [
                                             {
                                                 "target":  "portable",
                                                 "arch":  [
                                                              "x64"
                                                          ]
                                             }
                                         ],
                              "icon":  "build/icon.ico",
                              "signAndEditExecutable":  false
                          }
              }
}